{
  "$schema": "http://json.schemastore.org/template",
  "author": "Nick Protopsaltis",
  "classifications": ["Console", "TUI", "Terminal"],
  "identity": "SharpConsoleUI.TuiDashboard",
  "name": "SharpConsoleUI TUI Dashboard",
  "shortName": "tui-dashboard",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "TuiDashboard",
  "preferNameDirectory": true,
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "The target framework for the project.",
      "datatype": "choice",
      "choices": [
        { "choice": "net10.0", "description": ".NET 10.0" },
        { "choice": "net9.0", "description": ".NET 9.0" },
        { "choice": "net8.0", "description": ".NET 8.0 (LTS)" }
      ],
      "defaultValue": "net9.0",
      "replaces": "net9.0"
    }
  },
  "postActions": [
    {
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "condition": true,
      "continueOnError": true,
      "description": "Restore NuGet packages",
      "manualInstructions": [
        { "text": "Run 'dotnet restore'" }
      ]
    }
  ]
}
