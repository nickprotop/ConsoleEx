{
  "$schema": "http://json.schemastore.org/template",
  "author": "SharpConsoleUI",
  "classifications": ["Console", "TUI", "SharpConsoleUI"],
  "identity": "SharpConsoleUI.SchostApp",
  "name": "SharpConsoleUI Desktop App (schost)",
  "shortName": "schost-app",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "ProjectName",
  "preferNameDirectory": true,
  "symbols": {
    "title": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "My App",
      "replaces": "PROJECT_TITLE",
      "description": "The display title for the application window"
    }
  }
}
